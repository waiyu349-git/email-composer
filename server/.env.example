# ─── Gmail IMAP ───────────────────────────────────────────────────────────────
# Your Gmail address (the "To" inbox being watched)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-to-address@gmail.com

# Generate at: https://myaccount.google.com/apppasswords
# (Google Account → Security → 2-Step Verification → App Passwords)
# Name it anything, e.g. "EmailSMS"
IMAP_PASS=xxxx-xxxx-xxxx-xxxx

# ─── Twilio ───────────────────────────────────────────────────────────────────
# From: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your Twilio phone number (must be SMS-capable, in E.164 format)
TWILIO_FROM_NUMBER=+15551234567

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# How often to poll the inbox (milliseconds). Default: 30000 (30s)
POLL_INTERVAL_MS=30000
